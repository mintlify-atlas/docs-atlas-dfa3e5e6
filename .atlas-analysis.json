  "keyFeatures": [
    "MDX-powered content authoring with embedded React components",
    "Document versioning to keep docs in sync with releases",
    "Internationalization (i18n) with Crowdin integration",
    "Rich plugin ecosystem (docs, blog, pages, sitemap, PWA, and more)",
    "Swizzling system for fine-grained theme component customization",
    "Built-in Algolia search integration",
    "Static site generation with fast client-side navigation (SPA)",
    "Scaffold CLI via create-docusaurus for instant project setup",
    "Flexible deployment to GitHub Pages, Netlify, Vercel, and more",
    "TypeScript support throughout"
  ],
  "publicApiSurface": [
    "npx create-docusaurus@latest",
